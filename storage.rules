rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Gallery uploads - admin only
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Payment proof uploads - anyone can upload (for booking flow)
    match /payments/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Package images - admin only
    match /packages/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
