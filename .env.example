# ============================================
# LIBURAN TERUS - Environment Variables
# ============================================
# Copy file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke repository!

# --- Firebase Configuration ---
# Dapatkan dari Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --- Midtrans Payment Gateway ---
# Dapatkan dari Midtrans Dashboard > Settings > Access Keys
# Gunakan Sandbox keys untuk testing, Production keys untuk live
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx

# --- App Configuration ---
VITE_APP_NAME=Liburan Terus
VITE_APP_URL=https://liburanterus.com
VITE_WHATSAPP_NUMBER=6281234567890
