# ============================================
# LIBURAN TERUS - Environment Variables
# ============================================
# Copy file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke repository!

# --- Supabase Configuration ---
# Dapatkan dari Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- Midtrans Payment Gateway ---
# Dapatkan dari Midtrans Dashboard > Settings > Access Keys
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx

# --- Cloudinary Upload ---
# Dapatkan dari Cloudinary Dashboard > Product Environment Credentials
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# --- App Configuration ---
VITE_APP_NAME=Liburan Terus
VITE_APP_URL=https://liburanterus.com
VITE_WHATSAPP_NUMBER=6281234567890
