# ============================================
# VAKANSI TRIP - Environment Variables
# ============================================
# Copy file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke repository!

# --- Supabase Configuration ---
# Dapatkan dari Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- Midtrans Payment Gateway ---
# Dapatkan dari Midtrans Dashboard > Settings > Access Keys
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx

# --- Cloudinary Upload ---
# Dapatkan dari Cloudinary Dashboard > Product Environment Credentials
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# --- App Configuration ---
# Ganti dengan nama brand dan domain Anda saat rebranding
VITE_APP_NAME=Nama Brand Anda
VITE_APP_URL=https://yourdomain.com
VITE_WHATSAPP_NUMBER=6281234567890

# --- Twitter/X Handle (opsional, untuk Twitter Card meta tag) ---
# Format: @handle (dengan @). Kosongkan jika belum punya.
VITE_TWITTER_HANDLE=

# --- Google Analytics (opsional) ---
# Dapatkan dari Google Analytics > Admin > Data Streams > Measurement ID (format: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=
